{
    "configurations": [
        {
            "name": "[Java] [Debug]",
            "type": "java",
            "request": "launch",
            "vmArgs": "-ea",
            "cwd": "${input:workingDirectory}",
            "mainClass": "${file}",
            "classPaths": [
                "$Runtime"
            ]
        },
        {
            "name": "[Java] [Debug] [AoC]: Load solutions under directory specified",
            "type": "java",
            "request": "launch",
            "vmArgs": "-ea",
            "cwd": "${workspaceFolder}",
            "args": [
                "${workspaceFolder}/Java/${input:yearName}/target/year${input:yearName}-${input:solutionVersion}.jar"
            ],
            "mainClass": "${file}",
            "classPaths": [
                "$Runtime"
            ],
            "preLaunchTask": "[maven package]",
            "projectName": "${input:launcherName}"
        },
        {
            "name": "[Python] [Debug]",
            "type": "debugpy",
            "request": "launch",
            "justMyCode": false,
            "program": "${file}",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env",
            "cwd": "${input:workingDirectory}"
        },
        {
            "name": "[C/C++] [Launch]",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/exe_${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${input:workingDirectory}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "[C/C++] [CMAKE] [GDB] [Launch]",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "cwd": "${input:workingDirectory}",
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "[C/C++] [MSVC] [CMake] [Launch]",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "cwd": "${input:workingDirectory}"
        },
        {
            "name": "[Node] [Debug]",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${input:workingDirectory}",
            "outFiles": [
                "${workspaceFolder}/**/*.(m|c|)js",
                "!**/node_modules/**"
            ]
        }
    ],
    "inputs": [
        {
            "id": "projectName",
            "type": "pickString",
            "default": "year2023",
            "options": [
                "year2023",
                "launcher"
            ],
            "description": "Project name for resolving the classpaths"
        },
        {
            "id": "workingDirectory",
            "type": "pickString",
            "default": "${fileDirname}",
            "options": [
                "${fileDirname}",
                "${fileDirname}/../resources",
                "${fileDirname}/../../resources",
                "${fileDirname}/../../../resources",
                "${fileDirname}/../../../resources/${fileDirnameBasename}",
                "${workspaceFolder}"
            ],
            "description": "Working directory of the launched program"
        },
        {
            "id": "yearName",
            "type": "pickString",
            "default": "2023",
            "options": [
                "2023"
            ],
            "description": "AoC solution year"
        },
        {
            "id": "solutionVersion",
            "type": "pickString",
            "default": "1.0-SNAPSHOT",
            "options": [
                "1.0-SNAPSHOT"
            ],
            "description": "AoC solution version"
        },
        {
            "id": "launcherName",
            "type": "pickString",
            "default": "launcher",
            "options": [
                "launcher"
            ],
            "description": "Select AoC Launcher Project Name"
        }
    ],
    "version": "2.0.0"
}